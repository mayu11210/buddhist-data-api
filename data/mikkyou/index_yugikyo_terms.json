    {
      "term": "大日",
      "term_kana": "",
      "sanskrit": "Mahāvairocana",
      "definition": "大日如来。密教の本尊。遮那と同義。法身そのもの。",
      "kaimyo_suitable": true,
      "kaimyo_chars": [
