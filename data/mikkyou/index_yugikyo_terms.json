          "context_position": 20507,
          "sanskrit_in_context": []
        },
        {
          "corpus_id": "yugikyo",
          "context": "〕、オンバザラアボキャシッテイアギニアク〔不空成就如来の火の真言〕、オンバザラサトババジリアギニウム〔金剛波羅蜜の火の真言〕",
          "context_position": 20539,
          "sanskrit_in_context": []
        },
        {
          "corpus_id": "yugikyo",
