        },
        {
          "corpus_id": "dainichikyo-sho-vol7",
          "context": "は摩羅庾〔まらゆ〕と名づける。これは山の名である。すなわち、『智論』にいう「摩梨山〔まりせん〕を除いては、さらに栴檀を出す処がな",
          "context_position": 45975,
          "raw_form": "智論"
        }
