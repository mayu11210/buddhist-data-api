    {
      "term": "荘子",
      "aliases": [],
      "occurrence_count": 2,
      "occurrences": [
        {
          "corpus_id": "sankyo-shiki",
          "context": "人になったと伝えられる王子喬を探したずねては仲間になる。また『荘子』に誌されているあの鵬の天上のすみかを観てまわったり、淮南王が",
          "context_position": 18838,
