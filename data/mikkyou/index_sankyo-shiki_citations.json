      "occurrences": [
        {
          "corpus_id": "sankyo-shiki",
          "context": "の上容貌が立派で背の高い人物です。中国の代表的な古典『易経』『書経』『詩経』『春秋』『礼記』等の九つの書物、あるいは八卦の説など",
          "context_position": 2194,
          "raw_form": "書経"
