      "occurrence_count": 5,
      "occurrences": [
        {
          "corpus_id": "dainichikyo-sho-vol5",
          "context": "めて動かさず、清らかな菩提心の妙高山王〔浄菩提心の妙高山王・須弥山〕を成す。だから「磐石に安住する」というのである。さらに、下",
          "context_position": 27297,
          "matched_form": "須弥山"
        },
        {
          "corpus_id": "dainichikyo-sho-vol5",
          "context": "南に、因陀羅釈天主〔いんだらしゃくてんしゅ・帝釈天〕を画く。須弥山に坐し、天衆が囲む。首に宝冠を戴き、身にさまざまな瓔珞を着け",
          "context_position": 31288,
          "matched_form": "須弥山"
        },
        {
          "corpus_id": "dainichikyo-sho-vol5",
          "context": "を、そのまま出世間の秘密の目じるしとする。ちょうど帝釈の像が須弥山〔妙高山王〕に安住するように、如来の因陀羅三昧〔いんだらざん",
          "context_position": 33011,
          "matched_form": "須弥山"
        },
        {
          "corpus_id": "dainichikyo-sho-vol5",
          "context": "昧〔いんだらざんまい〕もまたこの処を移さず、清らかな菩提心の須弥山〔浄菩提心の妙高山王〕を開き出す。ほかの法門もみな同じである",
          "context_position": 33066,
          "matched_form": "須弥山"
        },
        {
          "corpus_id": "dainichikyo-sho-vol5",
          "context": "地〔金剛地〕を起こし、この宝の王の宮殿〔宝王宮殿〕を観じて、須弥山の頂にあると見る。あらゆる一つひとつの荘厳は、みな後の品〔下",
          "context_position": 38164,
          "matched_form": "須弥山"
        }
      ]
    },
