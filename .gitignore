node_modules/
.next/

# ============================================================
#  環境変数（v1.10：APIキー等の秘密情報を絶対にコミットしない）
# ============================================================
.env
.env.*
!.env.example
*.env
*.env.*

# ============================================================
#  Cowork 作業用ツール類（untracked で運用）
#  CLAUDE.md「技術的ノウハウ」に記載の作業用ファイル群を隠す
# ============================================================

# .bat スクリプト（リポジトリ直下の作業用ツール）
/*.bat
# ただし以下のヘルパー bat は git 管理対象（2026-05-04 追加）
# commit_push.bat：メイン commit/push 運用ヘルパー
# commit_push_minimal.bat：phantom deletion 退避用 minimal stage 版
# fix_index_force.bat：.git/index 強制再構築用
!/commit_push.bat
!/commit_push_minimal.bat
!/fix_index_force.bat

# コミットメッセージ（毎回書き換える一時ファイル）
/commit_message*.txt

# 現在進行中の引き継ぎメモ（直下に置くルール）
/引き継ぎメモ_*.md

# 古いスクリプト・過去の引き継ぎメモ置き場
/_archive/

# Cowork JSON 反映時の一時翻訳ファイル（git に取り込まない）
_dev_references/_tmp_*.txt
# Cowork 編集用一時 Python（outputs フォルダ truncate 問題回避のため _dev_references/ 配下に置く）
_dev_references/_tmp_*.py

# LibreOffice lock files（recalc.py 等で生成・git に取り込まない）
.~lock.*#

# Python bytecode キャッシュ（api_server/ で生成・git に取り込まない・2026-04-27 v1.5 追加）
__pycache__/
*.pyc

# pytest キャッシュ（v1.10 追加）
.pytest_cache/
.coverage
htmlcov/

# OS / IDE 由来の生成物（v1.10 追加）
.DS_Store
Thumbs.db
.vscode/
.idea/
